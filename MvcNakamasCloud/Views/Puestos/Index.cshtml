@model List<MvcNakamasCloud.ViewModels.PuestoViewModel>
@{
    ViewData["Title"] = "Puestos";
}

<!-- Encabezado -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Puestos</li>
            </ol>
        </nav>
        <h2 class="fw-bold"><i class="fa-solid fa-briefcase text-primary me-2"></i>Listado de Puestos</h2>
        <p class="text-muted mb-0">Gestione los puestos de trabajo de la organización.</p>
    </div>
    <a href="/Puestos/Crear" class="btn btn-primary btn-lg shadow-sm">
        <i class="fa-solid fa-plus me-2"></i>Nuevo Puesto
    </a>
</div>

<!-- Tabla -->
<div class="card shadow-sm border-0 overflow-hidden" style="border-radius: 12px;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr class="text-uppercase small text-muted fw-bold" style="letter-spacing: 0.5px;">
                    <th class="ps-4 py-3">Puesto</th>
                    <th>Departamento</th>
                    <th>Descripción</th>
                    <th>Estado</th>
                    <th class="text-center pe-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var puesto in Model)
                {
                    <tr>
                        <td class="ps-4 py-3">
                            <div class="fw-bold text-dark">@puesto.NombrePuesto</div>
                            <div class="text-muted small">ID: @puesto.CodigoPuesto</div>
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@puesto.NombreDepartamento</div>
                        </td>
                        <td class="text-muted small">
                            @puesto.DescripcionPuesto
                        </td>
                        <td>
                            @if (puesto.Activo)
                            {
                                <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3 py-2 text-uppercase" style="font-size: 0.65rem;">Activo</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger px-3 py-2 text-uppercase" style="font-size: 0.65rem;">Inactivo</span>
                            }
                        </td>
                        <td class="text-center pe-4">
                            <div class="btn-group shadow-sm" role="group">
                                <a href="/Puestos/Editar/@puesto.IdPuesto"
                                   class="btn btn-white btn-sm border-end" title="Editar">
                                    <i class="fa-solid fa-pen text-muted"></i>
                                </a>
                                @if (puesto.Activo)
                                {
                                    <a href="/Puestos/Desactivar/@puesto.IdPuesto"
                                       class="btn btn-white btn-sm text-warning" title="Desactivar">
                                        <i class="fa-solid fa-ban"></i>
                                    </a>
                                }
                                else
                                {
                                    <a href="/Puestos/Activar/@puesto.IdPuesto"
                                       class="btn btn-white btn-sm text-success" title="Activar">
                                        <i class="fa-solid fa-check"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-white border-top-0 py-3">
        <span class="text-muted small">Total: <strong>@Model.Count</strong> puestos</span>
    </div>
</div>

<style>
    .btn-white {
        background-color: #fff;
        border: 1px solid #dee2e6;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }

    .table thead th {
        border-top: 0;
    }
</style>