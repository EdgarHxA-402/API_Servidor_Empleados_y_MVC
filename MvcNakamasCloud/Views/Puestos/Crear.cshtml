@model MvcNakamasCloud.ViewModels.PuestoFormViewModel

@{
    ViewData["Title"] = "Nuevo Puesto";
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        <strong>Error:</strong> @ViewBag.Error
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/Puestos" class="text-decoration-none text-muted">Puestos</a></li>
                <li class="breadcrumb-item active">Nuevo Puesto</li>
            </ol>
        </nav>
        <h2 class="fw-bold"><i class="fa-solid fa-briefcase text-primary me-2"></i>Nuevo Puesto</h2>
    </div>
    <div class="d-flex gap-2">
        <a href="/Puestos" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-2"></i>Cancelar
        </a>
        <button type="submit" form="formCrear" class="btn btn-primary">
            <i class="fa-solid fa-floppy-disk me-2"></i>Guardar
        </button>
    </div>
</div>

<form id="formCrear" method="post" action="/Puestos/Crear">
    @Html.AntiForgeryToken()

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 py-3 ps-4">
            <h5 class="mb-0 fw-bold text-dark">
                <i class="fa-solid fa-plus text-primary me-2"></i>Información del Puesto
            </h5>
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CodigoPuesto" class="form-label fw-semibold text-muted small">Código</label>
                    <input asp-for="CodigoPuesto" class="form-control bg-light border-0 py-2 fw-bold text-primary" />
                    <span asp-validation-for="CodigoPuesto" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="NombrePuesto" class="form-label fw-semibold text-muted small">Nombre</label>
                    <input asp-for="NombrePuesto" class="form-control bg-light border-0 py-2" />
                    <span asp-validation-for="NombrePuesto" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="IdDepartamento" class="form-label fw-semibold text-muted small">Departamento</label>
                    <select asp-for="IdDepartamento" class="form-select bg-light border-0 py-2">
                        <option value="">-- Seleccione un departamento --</option>
                        @foreach (var dept in Model.Departamentos)
                        {
                            <option value="@dept.IdDepartamento">@dept.NombreDepartamento</option>
                        }
                    </select>
                    <span asp-validation-for="IdDepartamento" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DescripcionPuesto" class="form-label fw-semibold text-muted small">Descripción</label>
                    <textarea asp-for="DescripcionPuesto" class="form-control bg-light border-0 py-2" rows="3"></textarea>
                </div>
            </div>
        </div>
    </div>
</form>